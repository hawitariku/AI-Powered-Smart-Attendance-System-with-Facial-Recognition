# Application Configuration
ENV=development
DEBUG=True
HOST=127.0.0.1
PORT=8002

# Security Keys (CHANGE THESE IN PRODUCTION!)
# Generate SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Generate ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# Database Configuration
# Development (SQLite)
DATABASE_URL=sqlite:///./attendance.db

# Production (PostgreSQL - recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/attendance_db

# Production (MySQL - alternative)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/attendance_db

# JWT Configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:8002,http://127.0.0.1:8002

# Email Configuration (for notifications - optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@attendance.com

# Face Recognition Configuration
RECOGNITION_THRESHOLD=0.55
CONFLICT_THRESHOLD=0.55
LIVENESS_TIMEOUT=20.0
LIVENESS_STEPS=1

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60

# Monitoring (optional)
SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
LOG_FILE=debug_live.log

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# Session Configuration
SESSION_TIMEOUT=3600  # 1 hour in seconds
